# Optional opt-out from the default Docker Hardened runtime images.
# Uncomment these to force the upstream non-DHI images instead.

# PYTHON_BUILD_IMAGE=python:3.13-slim
# PYTHON_RUNTIME_IMAGE=python:3.13-slim
# NGINX_RUNTIME_IMAGE=nginx:1.27-alpine
# EDGE_PROXY_IMAGE=nginx:1.27-alpine
# SMOKE_RUNNER_IMAGE=python:3.13-slim

# Optional Backstage portal integration. The repo carries a minimal Backstage
# app under backstage/app, while the runtime artifact vendored by other repos
# only carries catalog metadata.
# BACKSTAGE_ENABLED=false
# BACKSTAGE_BUILD_ENABLED=true
# BACKSTAGE_BUILD_CONTEXT=./backstage/app
# BACKSTAGE_IMAGE=apim-simulator-backstage:local
# BACKSTAGE_PORT=7007

# Runtime UIDs/GIDs for non-root containers.
APP_UID=65532
APP_GID=65532
NGINX_UID=101
NGINX_GID=101
