%%{init: {"theme": "base", "themeVariables": {"background": "#ffffff"}}}%%
C4Dynamic
    title Sentiment in-pod SST inference path

    Container(router, "sentiment-router", "NGINX", "Routes /api/* traffic to the API")
    Container(api, "sentiment-api", "API service", "Runs SST inference and emits traces")
    Container(sst, "SST classifier", "Transformers.js pipeline", "Loaded inside sentiment-api")

    RelIndex(1, router, api, "Forward /api/* to 8080")
    RelIndex(2, api, sst, "Classify sentiment in-process")
    UpdateLayoutConfig($c4ShapeInRow="3", $c4BoundaryInRow="1")
