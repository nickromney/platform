if [ -f /etc/profile.d/homebrew.sh ]; then
  . /etc/profile.d/homebrew.sh
fi

export EDITOR=nvim
export VISUAL=nvim

autoload -Uz compinit
if ! typeset -f compdef >/dev/null 2>&1; then
  compinit
fi

_platform_completion_dir="${HOME}/.local/share/platform-devcontainer/completions/zsh"
if [ -d "${_platform_completion_dir}" ]; then
  for _platform_completion in "${_platform_completion_dir}"/*.zsh; do
    [ -r "${_platform_completion}" ] || continue
    . "${_platform_completion}"
  done
fi
unset _platform_completion_dir _platform_completion

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi
