    {
      "id": "grafana-victorialogs",
      "hcl_key": "grafana",
      "image_name": "grafana-victorialogs",
      "default_tag": "12.3.1-v0.28.0",
      "build": {
        "context": "generated-grafana-victorialogs",
        "dockerfile": "Dockerfile",
        "tag": "grafana-plugin-version",
        "grafana_base_image": {
          "source": "docker.io/grafana/grafana",
          "tag": "12.3.1",
          "cache_repo": "platform-cache/grafana-grafana"
        },
        "plugin_fetch_image": {
          "source": "docker.io/library/alpine",
          "tag": "3.22",
          "cache_repo": "platform-cache/library-alpine"
        },
        "plugin_archive": {
          "terraform_version_variable": "grafana_victoria_logs_plugin_version",
          "terraform_sha256_variable": "grafana_victoria_logs_plugin_sha256",
          "url_template": "https://github.com/VictoriaMetrics/victorialogs-datasource/releases/download/v{version}/victoriametrics-logs-datasource-v{version}.zip",
          "cache_dir": ".run/kind/plugin-cache",
          "context_archive_name": "victorialogs.zip",
          "verify": "sha256"
        },
        "version_tag_strategy": "grafana-tag-plus-plugin-version"
      },
      "fingerprint_sources": [
        "kubernetes/kind/images/grafana-victorialogs/Dockerfile",
        "kubernetes/workflow/image-catalog.json"
      ],
      "version_check": {
        "mode": "checked-elsewhere",
        "reason": "local Grafana image version is derived from catalog plugin inputs; the VictoriaLogs plugin release is reported by check-component-version.sh"
      }
    },
