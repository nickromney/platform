# Copy this file to .env and set the local demo credentials you want this repo
# to use for bootstrap flows.
#
# Example:
#   cp .env.example .env

# Used for Gitea admin, SigNoz login, and Argo CD admin.
PLATFORM_ADMIN_PASSWORD=

# Used for the demo sentiment and subnetcalc users.
PLATFORM_DEMO_PASSWORD=

# Required for the compose-based browser auth flows.
# Generate with: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
OAUTH2_PROXY_COOKIE_SECRET=
