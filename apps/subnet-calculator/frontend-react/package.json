{
  "name": "frontend-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node server.js",
    "lint": "biome check --write src/",
    "lint:check": "biome check src/",
    "format": "biome format --write src/",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:stack12": "playwright test tests/stack12-auth.spec.ts -c playwright.stack12.config.ts",
    "test:easyauth-mock": "playwright test tests/easyauth-mock-logout.spec.ts -c playwright.easyauth-mock.config.ts"
  },
  "dependencies": {
    "@azure/identity": "^4.6.0",
    "@azure/msal-browser": "^4.29.1",
    "@azure/msal-react": "^3.0.28",
    "@subnet-calculator/shared-frontend": "file:../shared-frontend",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "jsonwebtoken": "9.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0"
  }
}
