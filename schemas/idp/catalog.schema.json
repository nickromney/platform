{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local IDP catalog",
  "type": "object",
  "required": ["schema_version", "applications"],
  "properties": {
    "schema_version": { "const": "platform.idp/v1" },
    "core_components": { "type": "object" },
    "applications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "display_name", "owner", "environments", "deployment", "secrets", "scorecard"],
        "properties": {
          "name": { "type": "string" },
          "display_name": { "type": "string" },
          "owner": { "type": "string" },
          "environments": { "type": "array" },
          "deployment": { "type": "object" },
          "secrets": { "type": "array" },
          "scorecard": { "type": "object" }
        }
      }
    }
  }
}
