  "preload_alignment_images": [
    {
      "id": "argocd",
      "component": "ArgoCD",
      "version_check": {
        "mode": "external",
        "latest_lookup_policy": "preferred-image",
        "preload_alignment_policy": "exact-ref",
        "checked_elsewhere": "preferred image availability and preload alignment sections",
        "reason": "Argo CD may use a hardened preferred image ref instead of the chart appVersion tag"
      },
      "preload_alignment": {
        "kind": "exact-ref",
        "line_regex": "^[[:space:]]*((dhi\\.io/argocd)|(quay\\.io/argoproj/argocd)):",
        "expected_source": "argocd_image_ref"
      }
    },
    {
      "id": "prometheus",
      "component": "Prometheus",
      "version_check": {
        "mode": "external",
        "latest_lookup_policy": "chart-app-version",
        "preload_alignment_policy": "repo-tag",
        "checked_elsewhere": "chart appVersion and preload alignment sections",
        "reason": "Prometheus preload tags are expected to track the Helm chart appVersion"
      },
      "preload_alignment": {
        "kind": "repo-tag",
        "line_regex": "^[[:space:]]*quay\\.io/prometheus/prometheus:",
        "tag_extract_sed": "s|^[[:space:]]*quay\\.io/prometheus/prometheus:([^[:space:]]+).*|\\1|",
        "expected_source": "prometheus_chart_app_version",
        "enabled_by": "EXPECT_PROMETHEUS"
      }
    },
