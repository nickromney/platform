{
  "allowed_origins": [
    "${APIM_ALLOWED_ORIGIN_BROWSER_LOCALHOST}",
    "${APIM_ALLOWED_ORIGIN_OPERATOR_CONSOLE}",
    "${APIM_ALLOWED_ORIGIN_VITE}",
    "${APIM_ALLOWED_ORIGIN_GATEWAY}"
  ],
  "allow_anonymous": true,
  "trace_enabled": true,
  "proxy_retry_statuses": [429, 500, 502, 503, 504],
  "products": {
    "ai-gateway": {
      "name": "AI Gateway",
      "description": "Local OpenAI-compatible AI gateway example product",
      "require_subscription": false
    }
  },
  "backends": {
    "openai-primary-local": {
      "url": "http://ai-openai-primary:8080",
      "description": "Primary local OpenAI-compatible mock backend"
    },
    "openai-secondary-local": {
      "url": "http://ai-openai-secondary:8080",
      "description": "Secondary local OpenAI-compatible mock backend"
    }
  },
  "ai_gateway": {
    "strategy": "priority",
    "circuit_breaker": {
      "enabled": true,
      "trip_status_codes": [429],
      "trip_status_code_ranges": ["5xx"],
      "honor_retry_after": true,
      "open_duration_seconds": 30
    },
    "deployments": {
      "gpt-4o-mini": {"backend_ids": ["openai-primary-local", "openai-secondary-local"]},
      "text-embedding-3-small": {"backend_ids": ["openai-primary-local", "openai-secondary-local"]}
    }
  },
  "apis": {
    "ai-gateway": {
      "name": "AI Gateway",
      "path": "ai",
      "upstream_base_url": "http://ai-openai-primary:8080",
      "upstream_path_prefix": "",
      "backend": "openai-primary-local",
      "products": ["ai-gateway"],
      "policies_xml": "<policies><inbound><llm-token-limit counter-key=\"ai-gateway-local\" tokens-per-minute=\"100\" estimate-prompt-tokens=\"true\" remaining-tokens-header-name=\"X-Remaining-Tokens\" tokens-consumed-header-name=\"X-Tokens-Consumed\" /></inbound><backend /><outbound /><on-error /></policies>",
      "operations": {
        "health": {
          "name": "Backend Health",
          "method": "GET",
          "url_template": "/health"
        },
        "chat-completions": {
          "name": "OpenAI Chat Completions",
          "method": "POST",
          "url_template": "/v1/chat/completions"
        },
        "azure-chat-completions": {
          "name": "Azure OpenAI Chat Completions",
          "method": "POST",
          "url_template": "/openai/deployments/{deployment}/chat/completions"
        },
        "embeddings": {
          "name": "OpenAI Embeddings",
          "method": "POST",
          "url_template": "/v1/embeddings"
        },
        "azure-embeddings": {
          "name": "Azure OpenAI Embeddings",
          "method": "POST",
          "url_template": "/openai/deployments/{deployment}/embeddings"
        }
      }
    }
  }
}
