#!/bin/bash
# Cloud3 (AWS) egress firewall rules
# Applied on outbound gateway (10.10.1.254)
# AWS internal uses 172.31.1.0/24
set -euo pipefail
if [ "${TRACE_PROVISIONING:-0}" = "1" ]; then
    set -x
fi

# Default: drop forwarded traffic
iptables -P FORWARD DROP

# Allow established/related
iptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT

# Allow AWS internal -> SD-WAN tunnel overlay
iptables -A FORWARD -s 172.31.1.0/24 -d 192.168.1.0/24 -j ACCEPT

# Allow gateway layer -> tunnel
iptables -A FORWARD -s 10.10.1.0/24 -d 192.168.1.0/24 -j ACCEPT

# Allow AWS internal -> cloud1 external VIPs (Azure)
iptables -A FORWARD -s 172.31.1.0/24 -d 172.16.10.0/24 -j ACCEPT

# Allow AWS internal -> cloud2 external VIPs (on-prem)
iptables -A FORWARD -s 172.31.1.0/24 -d 172.16.11.0/24 -j ACCEPT

# SNAT outbound through WireGuard
iptables -t nat -A POSTROUTING -s 172.31.1.0/24 -o wg0 -j MASQUERADE
iptables -t nat -A POSTROUTING -s 10.10.1.0/24 -o wg0 -j MASQUERADE

# DNAT inbound VIP traffic to nginx
iptables -t nat -A PREROUTING -d 172.16.12.3 -p tcp --dport 80 \
    -j DNAT --to-destination 10.10.1.60:8080
iptables -t nat -A PREROUTING -d 172.16.12.3 -p tcp --dport 443 \
    -j DNAT --to-destination 10.10.1.60:8443

# Log + drop everything else
iptables -A FORWARD -j LOG --log-prefix "EGRESS-DENIED-CLOUD3: " --log-level 4
iptables -A FORWARD -j DROP

# Block outbound internet from the gateway VM itself
iptables -A OUTPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
iptables -A OUTPUT -d 127.0.0.0/8 -j ACCEPT
iptables -A OUTPUT -d 10.0.0.0/8 -j ACCEPT
iptables -A OUTPUT -d 172.16.0.0/12 -j ACCEPT
iptables -A OUTPUT -d 192.168.0.0/16 -j ACCEPT
iptables -A OUTPUT -j REJECT
