{
  "allowed_origins": [
    "${APIM_ALLOWED_ORIGIN_BROWSER_LOCALHOST}",
    "${APIM_ALLOWED_ORIGIN_OPERATOR_CONSOLE}",
    "${APIM_ALLOWED_ORIGIN_VITE}",
    "${APIM_ALLOWED_ORIGIN_GATEWAY}"
  ],
  "allow_anonymous": false,
  "oidc": {
    "issuer": "${OIDC_ISSUER_EXTERNAL}",
    "audience": "api-app",
    "jwks_uri": "http://keycloak:8080/realms/subnet-calculator/protocol/openid-connect/certs"
  },
  "products": {
    "hello": {
      "name": "Hello",
      "description": "Subscription plus JWT hello API",
      "require_subscription": true
    }
  },
  "subscription": {
    "required": true,
    "header_names": ["Ocp-Apim-Subscription-Key", "X-Ocp-Apim-Subscription-Key"],
    "subscriptions": {
      "hello-demo": {
        "id": "sub-hello-demo",
        "name": "hello-demo",
        "keys": {
          "primary": "hello-demo-key",
          "secondary": "hello-demo-key-secondary"
        },
        "products": ["hello"],
        "created_by": "publisher"
      }
    }
  },
  "apis": {
    "hello-api": {
      "name": "Hello API",
      "path": "api",
      "upstream_base_url": "http://hello-api:8000",
      "upstream_path_prefix": "/api",
      "products": ["hello"],
      "operations": {
        "health": {
          "name": "Health",
          "method": "GET",
          "url_template": "/health",
          "authz": {
            "required_roles": ["user"]
          }
        },
        "hello": {
          "name": "Hello",
          "method": "GET",
          "url_template": "/hello",
          "authz": {
            "required_roles": ["user"]
          }
        }
      }
    }
  }
}
