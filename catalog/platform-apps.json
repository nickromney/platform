        }
      ],
      "scorecard": {
        "runtime_profile": "restricted",
        "has_health_endpoint": true,
        "has_network_policy": true,
        "has_owner": true
      }
    },
    {
      "name": "sentiment",
      "display_name": "Sentiment",
      "owner": "team-dolphin",
      "lifecycle": "demo",
      "source": {
        "repo": "platform",
        "path": "apps/sentiment"
      },
      "deployment": {
        "strategy": "gitops",
        "controller": "argocd",
        "applications": ["dev", "uat"]
      },
      "environments": [
        {
          "name": "dev",
          "type": "development",
          "namespace": "dev",
          "route": "https://sentiment.dev.127.0.0.1.sslip.io",
          "rbac": {
            "group": "app-sentiment-dev",
            "viewer": true,
            "mutator": false
          }
        },
        {
          "name": "uat",
          "type": "acceptance",
          "namespace": "uat",
          "route": "https://sentiment.uat.127.0.0.1.sslip.io",
          "rbac": {
            "group": "app-sentiment-uat",
