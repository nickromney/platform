{
  "service": {
    "name": "aws-api-gateway-migration",
    "display_name": "Migrating From AWS API Gateway"
  },
  "allowed_origins": ["http://localhost:3007"],
  "allow_anonymous": true,
  "tenant_access": {
    "enabled": true,
    "primary_key": "local-dev-tenant-key"
  },
  "products": {
    "starter-usage-plan": {
      "name": "Starter Usage Plan",
      "description": "Local equivalent of a simple API Gateway usage plan",
      "require_subscription": true
    }
  },
  "subscription": {
    "required": true,
    "subscriptions": {
      "aws-migration-demo": {
        "id": "aws-migration-demo",
        "name": "aws-migration-demo",
        "keys": {
          "primary": "aws-migration-demo-key",
          "secondary": "aws-migration-demo-key-secondary"
        },
        "products": ["starter-usage-plan"],
        "created_by": "publisher"
      }
    }
  },
  "named_values": {
    "stage-name": {
      "value": "prod"
    }
  },
  "policy_fragments": {
    "inject-stage-header": "<set-header name=\"x-local-stage\" exists-action=\"override\"><value>{{stage-name}}</value></set-header>"
  },
  "backends": {
    "hello-backend": {
      "url": "http://hello-api:8000",
      "description": "Hello backend reused for the AWS migration starter"
    }
  },
  "apis": {
    "http-api": {
      "name": "http-api",
      "path": "prod",
      "upstream_base_url": "http://hello-api:8000",
      "upstream_path_prefix": "/api",
      "backend": "hello-backend",
      "products": ["starter-usage-plan"],
      "policies_xml": "<policies>\n  <inbound>\n    <include-fragment fragment-id=\"inject-stage-header\" />\n  </inbound>\n  <backend />\n  <outbound />\n  <on-error />\n</policies>",
      "operations": {
        "health": {
          "name": "health",
          "method": "GET",
          "url_template": "/health"
        },
        "hello": {
          "name": "hello",
          "method": "GET",
          "url_template": "/hello"
        }
      }
    }
  }
}
