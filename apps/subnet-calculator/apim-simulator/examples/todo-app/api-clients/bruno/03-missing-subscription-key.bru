meta {
  name: 03 Missing Subscription Key
  type: http
  seq: 3
}

get {
  url: {{apimBaseUrl}}/api/todos
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("missing key returns 401", function () {
    expect(res.getStatus()).to.equal(401);
  });

  test("missing key message is explicit", function () {
    const body = res.getBody();
    expect(body.detail).to.equal("Missing subscription key");
  });
}
