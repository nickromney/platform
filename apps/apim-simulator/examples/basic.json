{
  "allowed_origins": ["http://localhost:8000", "http://localhost:8307"],
  "allow_anonymous": true,
  "trace_enabled": true,
  "tenant_access": {
    "enabled": true,
    "primary_key": "local-dev-tenant-key",
    "secondary_key": "local-dev-tenant-key-secondary"
  },
  "products": {
    "default": {
      "name": "Default",
      "description": "Anonymous local development product",
      "require_subscription": false
    }
  },
  "apis": {
    "default": {
      "name": "Default",
      "path": "api",
      "products": ["default"],
      "operations": {
        "health": {
          "name": "Health",
          "method": "GET",
          "url_template": "/health"
        },
        "echo": {
          "name": "Echo",
          "method": "GET",
          "url_template": "/echo"
        }
      }
    }
  },
  "routes": [
    {
      "name": "demo-api",
      "path_prefix": "/api",
      "upstream_base_url": "http://apim-simulator:8000",
      "upstream_path_prefix": "/mock"
    }
  ]
}
