#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_python_files="$(mktemp)"
trap 'rm -f "$staged_python_files"' EXIT INT TERM

git diff --cached --name-only --diff-filter=ACMR -z -- '*.py' >"$staged_python_files"

if [ ! -s "$staged_python_files" ]; then
  exit 0
fi

xargs -0 uv run --extra dev ruff check --fix <"$staged_python_files"
xargs -0 uv run --extra dev ruff format <"$staged_python_files"
xargs -0 git add -- <"$staged_python_files"
