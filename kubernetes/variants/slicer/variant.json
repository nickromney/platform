{
  "schema_version": "platform.variant/v1",
  "id": "slicer",
  "path": "kubernetes/slicer",
  "label": "slicer",
  "guided_label": "Slicer",
  "class": "local-created-cluster",
  "family": "local",
  "lifecycle_mode": "create",
  "state_scope": "single-local",
  "contexts": ["local-substrate", "platform-stack"],
  "execution_adapter": {
    "type": "make",
    "make_dir": "kubernetes/slicer"
  },
  "state": {
    "runtime_scope": "slicer",
    "state_file": "terraform/.run/kubernetes-slicer/terraform.tfstate",
    "state_lock_file": "terraform/.run/kubernetes-slicer/.terraform.tfstate.lock.info"
  },
  "cluster_access": {
    "kubeconfig_path": "~/.kube/slicer-k3s.yaml",
    "kubeconfig_context": "slicer-k3s",
    "cluster_name": "slicer-k3s"
  },
  "stage_ladder": {
    "stages_dir": "kubernetes/slicer/stages",
    "target_profile_file": "kubernetes/slicer/targets/slicer.tfvars",
    "stage_files": {
      "100": "kubernetes/slicer/stages/100-cluster.tfvars",
      "200": "kubernetes/slicer/stages/200-cilium.tfvars",
      "300": "kubernetes/slicer/stages/300-hubble.tfvars",
      "400": "kubernetes/slicer/stages/400-argocd.tfvars",
      "500": "kubernetes/slicer/stages/500-gitea.tfvars",
      "600": "kubernetes/slicer/stages/600-policies.tfvars",
      "700": "kubernetes/slicer/stages/700-app-repos.tfvars",
      "800": "kubernetes/slicer/stages/800-gateway-tls.tfvars",
      "900": "kubernetes/slicer/stages/900-sso.tfvars"
    }
  },
  "readiness": {
    "command": "make -C kubernetes/slicer prereqs",
    "facets": ["operator_prereqs", "active_variant", "cluster_access", "host_access_path", "stage_contracts", "blockers"]
  },
  "blockers": {
    "conflicting_variants": ["kind", "lima"],
    "checks": ["check-kind-stopped", "check-lima-stopped"]
  },
  "registry": {
    "runtime_host": "192.168.64.1:5002",
    "push_host": "127.0.0.1:5002",
    "scheme": "http",
    "image_distribution_modes": ["pull", "local-cache", "airplane"],
    "default_image_distribution_mode": "local-cache"
  },
  "host_access_path": {
    "mode": "host-forwards-plus-proxy",
    "gateway_host_port": 443,
    "gateway_forward_port": 8443,
    "gateway_target_port": 30070,
    "shared_host_ports": [443, 30022, 30080, 30090, 31235, 3301, 3302],
    "requires_proxy": true,
    "requires_forward_process": true,
    "can_degrade": true
  },
  "network_profile": {
    "default": "cilium",
    "allowed": ["cilium", "default"]
  }
}
