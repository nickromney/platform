{
  "name": "subnetcalc-frontend-typescript-vite",
  "version": "1.0.0",
  "type": "module",
  "description": "TypeScript + Vite frontend for subnet calculator",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite",
    "build": "(cd ../shared-frontend && bun run build) && tsc && vite build",
    "preview": "vite preview",
    "type-check": "(cd ../shared-frontend && bun run build) && tsc --noEmit",
    "test": "playwright test",
    "test:stack12": "playwright test tests/stack12-gateway.spec.ts -c playwright.stack12.config.ts",
    "test:easyauth-mock": "playwright test tests/easyauth-mock.spec.ts -c playwright.easyauth-mock.config.ts",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:integration": "BASE_URL=http://localhost:3001 playwright test --config=playwright.integration.config.ts",
    "test:integration:stack4": "BASE_URL=http://localhost:3000 playwright test --config=playwright.integration.config.ts",
    "test:integration:headed": "BASE_URL=http://localhost:3001 playwright test --config=playwright.integration.config.ts --headed",
    "test:swa:stack4": "BASE_URL=http://localhost:4280 playwright test --config=playwright.swa.config.ts",
    "test:swa:stack5": "BASE_URL=http://localhost:4281 playwright test --config=playwright.swa.config.ts",
    "test:swa:headed": "BASE_URL=http://localhost:4280 playwright test --config=playwright.swa.config.ts --headed",
    "test:auth": "playwright test tests/auth-logout.spec.ts",
    "test:auth:headed": "playwright test tests/auth-logout.spec.ts --headed",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check . && (cd ../shared-frontend && bun run build) && tsc --noEmit"
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1",
    "@subnetcalc/shared-frontend": "file:../shared-frontend",
    "oidc-client-ts": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
