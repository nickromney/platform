meta {
  name: 04 Invalid Subscription Key
  type: http
  seq: 4
}

get {
  url: {{apimBaseUrl}}/api/todos
  body: none
  auth: none
}

headers {
  Accept: application/json
  Ocp-Apim-Subscription-Key: {{invalidSubscriptionKey}}
}

tests {
  test("invalid key returns 401", function () {
    expect(res.getStatus()).to.equal(401);
  });

  test("invalid key message is explicit", function () {
    const body = res.getBody();
    expect(body.detail).to.equal("Invalid subscription key");
  });
}
