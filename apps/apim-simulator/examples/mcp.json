{
  "allowed_origins": ["http://localhost:8000", "http://localhost:8307"],
  "allow_anonymous": true,
  "trace_enabled": true,
  "tenant_access": {
    "enabled": true,
    "primary_key": "local-dev-tenant-key",
    "secondary_key": "local-dev-tenant-key-secondary"
  },
  "products": {
    "mcp": {
      "name": "MCP",
      "description": "Subscription-protected MCP broker product",
      "require_subscription": true
    }
  },
  "subscription": {
    "required": true,
    "subscriptions": {
      "mcp-demo": {
        "id": "sub-mcp-demo",
        "name": "mcp-demo",
        "keys": {
          "primary": "mcp-demo-key",
          "secondary": "mcp-demo-key-secondary"
        },
        "products": ["mcp"],
        "created_by": "publisher"
      }
    }
  },
  "apis": {
    "mcp-server": {
      "name": "MCP Server",
      "path": "mcp",
      "type": "mcp",
      "upstream_base_url": "http://mcp-server:8080",
      "mcp_properties": {
        "transport_type": "sse",
        "endpoints": [
          {
            "name": "sse",
            "uri_template": "/sse"
          }
        ]
      },
      "products": ["mcp"]
    }
  }
}
