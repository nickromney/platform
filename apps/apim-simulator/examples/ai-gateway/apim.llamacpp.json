{
  "allowed_origins": [
    "${APIM_ALLOWED_ORIGIN_BROWSER_LOCALHOST}",
    "${APIM_ALLOWED_ORIGIN_OPERATOR_CONSOLE}",
    "${APIM_ALLOWED_ORIGIN_VITE}",
    "${APIM_ALLOWED_ORIGIN_GATEWAY}"
  ],
  "allow_anonymous": true,
  "trace_enabled": true,
  "proxy_timeout_seconds": 180,
  "proxy_retry_statuses": [429, 500, 502, 503, 504],
  "products": {
    "ai-gateway": {
      "name": "AI Gateway",
      "description": "Local APIM-style gateway in front of a host llama.cpp deployment",
      "require_subscription": false
    }
  },
  "backends": {
    "llamacpp-qwen-local": {
      "url": "http://host.docker.internal:8087",
      "description": "Host llama.cpp llama-server running Qwen2.5 0.5B Instruct GGUF"
    }
  },
  "ai_gateway": {
    "strategy": "priority",
    "circuit_breaker": {
      "enabled": true,
      "trip_status_codes": [429],
      "trip_status_code_ranges": ["5xx"],
      "honor_retry_after": true,
      "open_duration_seconds": 30
    },
    "deployments": {
      "qwen2.5-0.5b-instruct-q4_k_m": {"backend_ids": ["llamacpp-qwen-local"]}
    }
  },
  "apis": {
    "ai-gateway": {
      "name": "AI Gateway llama.cpp",
      "path": "ai",
      "upstream_base_url": "http://host.docker.internal:8087",
      "upstream_path_prefix": "",
      "backend": "llamacpp-qwen-local",
      "products": ["ai-gateway"],
      "policies_xml": "<policies><inbound><llm-token-limit counter-key=\"ai-gateway-llamacpp-local\" tokens-per-minute=\"4000\" estimate-prompt-tokens=\"true\" remaining-tokens-header-name=\"X-Remaining-Tokens\" tokens-consumed-header-name=\"X-Tokens-Consumed\" /></inbound><backend /><outbound /><on-error /></policies>",
      "operations": {
        "models": {
          "name": "OpenAI Models",
          "method": "GET",
          "url_template": "/v1/models"
        },
        "chat-completions": {
          "name": "OpenAI Chat Completions",
          "method": "POST",
          "url_template": "/v1/chat/completions"
        }
      }
    }
  }
}
