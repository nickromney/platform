{
  "realm": "platform",
  "enabled": true,
  "displayName": "Platform Local",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "groups": [
    { "name": "platform-admins" },
    { "name": "platform-viewers" },
    { "name": "app-sentiment-dev" },
    { "name": "app-subnetcalc-dev" }
  ],
  "clients": [
    {
      "clientId": "oauth2-proxy",
      "name": "OAuth2 Proxy",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "publicClient": false,
      "secret": "${OAUTH2_PROXY_CLIENT_SECRET}",
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8304/oauth2/*",
        "http://localhost:8003/oauth2/*",
        "http://localhost:18084/oauth2/*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "sentiment-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "sentiment-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "subnetcalc-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "api-app",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "sentiment-api",
      "name": "Sentiment API",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "api-app",
      "name": "SubnetCalc API",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "defaultDefaultClientScopes": ["profile", "email"],
  "users": [
    {
      "username": "demo@dev.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "demo@dev.test",
      "groups": [
        "/platform-viewers",
        "/app-sentiment-dev",
        "/app-subnetcalc-dev"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_DEMO_PASSWORD}",
          "temporary": false
        }
      ]
    }
  ]
}
