{
  "name": "frontend-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node server.js",
    "lint": "biome check --write src/",
    "lint:check": "biome check src/",
    "format": "biome format --write src/",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "playwright test",
    "test:server": "node --test server.test.js",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:stack12": "playwright test tests/stack12-auth.spec.ts -c playwright.stack12.config.ts",
    "test:easyauth-mock": "playwright test tests/easyauth-mock-logout.spec.ts -c playwright.easyauth-mock.config.ts"
  },
  "dependencies": {
    "@azure/identity": "^4.14.0-beta.3",
    "@azure/msal-browser": "^5.6.3",
    "@azure/msal-react": "^5.2.1",
    "@subnet-calculator/shared-frontend": "file:../shared-frontend",
    "express": "^5.2.1",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.3.0-canary-fd524fe0-20251121",
    "react-dom": "^19.3.0-canary-fd524fe0-20251121"
  },
  "overrides": {
    "jsonwebtoken": "9.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0-alpha-2026-04-10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0-canary-fd524fe0-20251121",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2-alpha.8",
    "vite": "^8.0.8"
  }
}
