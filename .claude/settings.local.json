      "Bash(go work *)",
      "Bash(go mod *)",
      "Bash(go env *)",
      "Bash(GONOSUMDB=platform.local go build ./subnetcalc/app/...)",
      "Bash(GONOSUMDB=platform.local GONOSUMCHECK=platform.local/* go build *)",
